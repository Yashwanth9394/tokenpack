<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <PackageId>PromptPack</PackageId>
    <Version>0.1.0</Version>
    <Description>Pack JSON data into token-efficient CSV for LLM prompts.</Description>
    <RootNamespace>PromptPack</RootNamespace>
    <AssemblyName>PromptPack</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

</Project>
